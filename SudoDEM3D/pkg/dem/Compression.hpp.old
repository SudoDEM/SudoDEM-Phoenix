			// Stress values
			Real wsxx, wsyy, wszz;
			Real cylinder_stress;		
		CompressionEngine() : firstRun(true), majorok(true), box_volume(0), Initial_boxVolume(0), 
			Init_boxVolume(0), Current_boxVolume(0), left_facet_pos(0), porosity(1), fmax(0),
			left_wall_s(0), right_wall_s(0), front_wall_s(0), back_wall_s(0), bottom_wall_s(0), top_wall_s(0),
			f_left(0), f_right(0), f_front(0), f_back(0), f_bottom(0), f_top(0),
			v_left(0), v_right(0), v_front(0), v_back(0), v_bottom(0), v_top(0),
			current_width(0), current_height(0), current_depth(0),
			iterate_num(0), solve_num(0), Flag_ForceTarget(false),
			x_area(0), y_area(0), z_area(0), loading_area(0),
			avg_xstiff(0), avg_ystiff(0), avg_zstiff(0), gain_x(0), gain_y(0), gain_z(0),
			rampNum(0),
			cubic_specimen(true), z_servo(true), continueFlag(false), shearMode(1),
			wall_radius(5.0), wall_fix(true), wall_radius0(0),
			gain_alpha(0.5), target_strain(0.15), iterate_num_max(100), solve_num_max(2000),
			echo_interval(1000), ramp_interval(10000), ramp_chunks(400),
			f_threshold(0.01), fmin_threshold(0.01), unbf_tol(0.01), wall_max_vel_single(1.), alpha(0.5),
			height0(0), width0(0), depth0(0), height(0), width(0), depth(0),
			left_wall_activated(true), right_wall_activated(true), front_wall_activated(true), 
			back_wall_activated(true), bottom_wall_activated(true), top_wall_activated(true),
			hydroStrain(false), hydroStrainRate(0.), debug(false), goalx(0), goaly(0), goalz(0),
			savedata_interval(12), max_vel(1.), externalWork(0), UnbalancedForce(1), 
							interStressControl(false),
							wsxx(0), wsyy(0), wszz(0), cylinder_stress(0),
							cylinder_force(0), num_pwall(0), truncate(false)		{
			strain[0] = strain[1] = strain[2] = 0;
			for(int j = 0; j < 4; j++) pos[j] = 0;
			for(int j = 0; j < 4; j++) {
				left_wpos[j] = 0; right_wpos[j] = 0; front_wpos[j] = 0; back_wpos[j] = 0; 
				bottom_wpos[j] = 0; top_wpos[j] = 0;
			}
			for(int j = 0; j < 6; j++) {
				wall_pos[j] = Vector3r::Zero();
				wall_stiffness[j] = 0.;
				wall_damping[j] = 0.8;
				wall_max_vel[j] = 1e5;
			}
					box_ax = box_ay = box_az = 0;
				}
			
				~CompressionEngine();
			
				void action();		void checkTarget();
		void cylinwall_go();
		void shear();
		unsigned int rampNum;
		
		// Missing method declarations
		void updateStiffness();
		Real ComputeUnbalancedForce(bool maxUnbalanced=false);
		void updateBoxSize();
		void hydroConsolidation();
		void generalConsolidation();
		void action_cubic();
		void action_cylindrical();
		Vector3r getStress();
			void servo(Real dt);
			void get_gain();
			void get_gainz();
			void getBox();
			void recordData();
			void consol_ss();
			void consol_ss_cylinder();
					void servo_cylinder(double dt);
					Matrix3r getStressTensor();
			
							// Cylinder-related member variables
							Real cylinder_force;
							int num_pwall;
							bool truncate;					
								// Use REGISTER_ATTRIBUTES for serialization - now supports up to 40 attributes
									REGISTER_ATTRIBUTES(BoundaryController, cubic_specimen, z_servo, continueFlag, shearMode,
									wall_radius, wall_fix, wall_radius0, gain_alpha, target_strain, iterate_num_max, solve_num_max,
									echo_interval, ramp_interval, ramp_chunks, f_threshold, fmin_threshold, unbf_tol,
									wall_max_vel_single, alpha, height0, width0, depth0, height, width, depth,
									left_wall_activated, right_wall_activated, front_wall_activated, back_wall_activated,
									bottom_wall_activated, top_wall_activated, hydroStrain, hydroStrainRate, debug,
									goalx, goaly, goalz, savedata_interval, max_vel, externalWork, UnbalancedForce,
									interStressControl, wsxx, wsyy, wszz, cylinder_stress, cylinder_force, num_pwall, truncate);		pybind11::list get_strain() const;
		pybind11::list get_porosity() const;
		
	DECLARE_LOGGER;

	virtual void pyRegisterClass(pybind11::module_ _module) override {
		checkPyClassRegistersItself("CompressionEngine");
		pybind11::class_<CompressionEngine, GlobalEngine, std::shared_ptr<CompressionEngine>> _classObj(_module, "CompressionEngine", "Compression engine for DEM simulations.");
