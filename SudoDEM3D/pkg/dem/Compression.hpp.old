		_classObj.def_readwrite("f_threshold", &CompressionEngine::f_threshold, "Force threshold");
		_classObj.def_readwrite("fmin_threshold", &CompressionEngine::fmin_threshold, "Minimum force threshold");
		_classObj.def_readwrite("unbf_tol", &CompressionEngine::unbf_tol, "Unbalanced force tolerance");
		_classObj.def_readwrite("wall_max_vel_single", &CompressionEngine::wall_max_vel_single, "Maximum wall velocity");
		_classObj.def_readwrite("alpha", &CompressionEngine::alpha, "Alpha parameter");
		_classObj.def_readwrite("height0", &CompressionEngine::height0, "Initial height");
