		_classObj.def_readwrite("max_vel", &CompressionEngine::max_vel, "Maximum velocity");
		_classObj.def_readwrite("externalWork", &CompressionEngine::externalWork, "External work");
		_classObj.def_readwrite("UnbalancedForce", &CompressionEngine::UnbalancedForce, "Unbalanced force");
		_classObj.def_readwrite("interStressControl", &CompressionEngine::interStressControl, "Inter stress control");
