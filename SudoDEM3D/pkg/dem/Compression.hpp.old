class State;

class Scene;
class State;


/*! \brief Controls the stress on the boundaries of a box and compute strain-like and stress-like quantities for the packing. The algorithms used have been developed initialy for simulations reported in [Chareyre2002a] and [Chareyre2005]. They have been ported to SudoDEM in a second step and used in e.g. [Kozicki2008],[Scholtes2009b],[Jerier2010b].
*/

class CompressionEngine : public BoundaryController
{
	private :
		bool firstRun;
		std::ofstream out;
		bool majorok;
		shared_ptr<Body> box [6];
		shared_ptr<NewtonIntegrator> newton;
		enum {left_wall=0,right_wall,front_wall,back_wall,bottom_wall,top_wall};

		inline const Vector3r getForce(Scene* rb, Body::id_t id){ return rb->forces.getForce(id); }
	public :
		Real wall_stiffness[6];
		Real pos[4];
		Real left_wpos[4];
		Real right_wpos[4];
		Real front_wpos[4];
		Real back_wpos[4];
		Real bottom_wpos[4];
		Real top_wpos[4];
		Real x_area;
		Real y_area;
		Real z_area;
		Real loading_area;
		Vector3r wall_pos[6];
		Real avg_xstiff;
		Real avg_ystiff;
		Real avg_zstiff;
		Real gain_x, gain_y, gain_z;
		#ifdef SOLE_GAIN
		double wsxx_left,wsxx_right,wsyy_front,wsyy_back,wszz_top,wszz_bottom;
		Real gain_x1, gain_y1, avg_xstiff1, avg_ystiff1, gain_z1, avg_zstiff1;
		#endif
		Real strain[3];
		Real particlesVolume;
		//std::vector<Real> stress;
		//std::vector<Real> strainRate;
		Real wall_damping[6];
		//initial box size
		Real box_volume;
		Real Initial_boxVolume;
		Real Init_boxVolume;
		Real Current_boxVolume;
		//cylinder parameters
		Real left_facet_pos;
		//current box size
		Real box_ax;
		Real box_ay;
		Real box_az;
		Real porosity;
		Real fmax;
		//wall stress
		Real left_wall_s;
		Real right_wall_s;
		Real front_wall_s;
		Real back_wall_s;
		Real bottom_wall_s;
		Real top_wall_s;
		//current force
		Real f_left;
		Real f_right;
		Real f_front;
		Real f_back;
		Real f_bottom;
		Real f_top;
		//current velocity
		Real v_left;
		Real v_right;
		Real v_front;
		Real v_back;
		Real v_bottom;
		Real v_top;
		//current position
		//Real pos_left;
		//Real pos_right;
		//Real pos_front;
		//Real pos_back;
		//Real pos_bottom;
		//Real pos_top;
		//stress control
		//current position
		//Real stress[3];
		//Real strainRate[3];
		// wall velocity limits
		Real wall_max_vel[6];
		// wall positions
		Real current_width;
		Real current_height;
		Real current_depth;
		// iteration numbers
		//unsigned int iterate_num;
		//unsigned int solve_num;
		// flag
		bool Flag_ForceTarget;
		// wall friction
		//Real wall_friction;
		// wall servo-control
		//Real wall_ux_servo;
		//unsigned int servo_time;
		//current
		//Real wall_tangential_stiffness;
		// parameters for stress/strain control
		// control variables
		unsigned int iterate_num;
		unsigned int solve_num;
		// attributes from the macro
		bool cubic_specimen;
		bool z_servo;
		bool continueFlag;
		unsigned int shearMode;
		double wall_radius;
		bool wall_fix;
		double wall_radius0;
		double gain_alpha;
		double target_strain;
		unsigned int iterate_num_max;
		unsigned int solve_num_max;
		unsigned int echo_interval;
		unsigned int ramp_interval;
		unsigned int ramp_chunks;
		Real f_threshold;
		Real fmin_threshold;
		Real unbf_tol;
		Real wall_max_vel_single;
		Real alpha;
		Real height0;
		Real width0;
		Real depth0;
		Real height;
		Real width;
		Real depth;
		bool left_wall_activated;
		bool right_wall_activated;
		bool front_wall_activated;
		bool back_wall_activated;
		bool bottom_wall_activated;
		bool top_wall_activated;
		bool hydroStrain;
		Real hydroStrainRate;
		bool debug;
		Real goalx;
		Real goaly;
		Real goalz;
		unsigned int savedata_interval;
		Real max_vel;
		Real externalWork;
