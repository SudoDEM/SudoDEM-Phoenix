		_classObj.def_readwrite("front_wall_activated", &CompressionEngine::front_wall_activated, "Front wall activated");
		_classObj.def_readwrite("back_wall_activated", &CompressionEngine::back_wall_activated, "Back wall activated");
		_classObj.def_readwrite("bottom_wall_activated", &CompressionEngine::bottom_wall_activated, "Bottom wall activated");
		_classObj.def_readwrite("top_wall_activated", &CompressionEngine::top_wall_activated, "Top wall activated");
		_classObj.def_readwrite("hydroStrain", &CompressionEngine::hydroStrain, "Hydro strain");
		_classObj.def_readwrite("hydroStrainRate", &CompressionEngine::hydroStrainRate, "Hydro strain rate");
		_classObj.def_readwrite("debug", &CompressionEngine::debug, "Debug flag");
		_classObj.def_readwrite("goalx", &CompressionEngine::goalx, "Goal X");
		_classObj.def_readwrite("goaly", &CompressionEngine::goaly, "Goal Y");
		_classObj.def_readwrite("goalz", &CompressionEngine::goalz, "Goal Z");
